{
  "name": "threat-terminal",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push:dev": "supabase db push --project-ref $SUPABASE_DEV_REF",
    "db:migrate:prod": "npm run db:dump:prod && supabase db push --project-ref $SUPABASE_PROD_REF",
    "db:dump:prod": "supabase db dump --project-ref $SUPABASE_PROD_REF -f backups/pre-migration-$(date +%Y%m%d-%H%M%S).sql",
    "db:reset:dev": "supabase db reset --project-ref $SUPABASE_DEV_REF"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.5.0",
    "leo-profanity": "^1.9.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "openai": "^6.25.0",
    "supabase": "^2.78.1",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
